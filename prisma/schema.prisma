generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DeviceType {
  ESP32
  RASPBERRY
  OTHER
}

enum DataSourceType {
  GENERATION
  CONSUMPTION
  BIDIRECTIONAL
}

enum DeviceStatus {
  ONLINE
  OFFLINE
  MAINTENANCE
  DISABLED
}

enum IngestionProtocol {
  HTTP_REST
  MQTT
  WEBSOCKET
  TCP
  LORA
  UNKNOWN
}

enum HistoryReason {
  INITIAL
  AVERAGE_CHANGE
  OUT_OF_RANGE
  REGULAR_INTERVAL
  MANUAL_IMPORT
}

enum SummaryGranularity {
  HOUR
  DAY
  MONTH
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  INGEST
  CONFIG_CHANGE
  RBAC_CHANGE
  DEVICE_REGISTER
}

model Usuario {
  id                     String                  @id @default(cuid())
  nombre                 String
  email                  String                  @unique
  password               String
  roleId                 String
  role                   Rol                     @relation(fields: [roleId], references: [id], onDelete: Restrict)
  auditoria              Auditoria[]
  dispositivos           Dispositivo[]
  configuracionMonitoreo ConfiguracionMonitoreo?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt

  @@index([roleId])
  @@map("Usuarios")
}

model Rol {
  id          String       @id @default(cuid())
  nombre      String       @unique
  descripcion String?
  activo      Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  usuarios    Usuario[]
  permisos    RolPermiso[]

  @@map("Roles")
}

model Permiso {
  id          String       @id @default(cuid())
  clave       String       @unique
  descripcion String?
  modulo      String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  roles       RolPermiso[]

  @@index([modulo])
  @@map("Permisos")
}

model RolPermiso {
  rolId     String
  permisoId String
  rol       Rol      @relation(fields: [rolId], references: [id], onDelete: Cascade)
  permiso   Permiso  @relation(fields: [permisoId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([rolId, permisoId])
  @@index([permisoId])
  @@map("RolesPermisos")
}

/// @deprecated Modelo legacy del sistema anterior. No insertar datos nuevos.
/// Conservado por compatibilidad. Ver Dispositivo + LecturaDispositivo + LecturaUnificada.
model SistemaFotovoltaico {
  id                 String             @id @default(cuid())
  nombreSistema      String
  ubicacion          String
  potenciaInstalada  Decimal            @db.Decimal(10, 2)
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  datoTiempoReal     DatosTiempoReal?
  historialLecturas  HistorialLectura[]
  resumenesDiarios   ResumenDiario[]
  resumenesMensuales ResumenMensual[]

  @@index([ubicacion])
  @@map("SistemasFotovoltaicos")
}

/// @deprecated Modelo legacy del sistema anterior. No insertar datos nuevos.
/// Conservado por compatibilidad. Ver Dispositivo + LecturaDispositivo + LecturaUnificada.
model DatosTiempoReal {
  id                  String              @id @default(cuid())
  sistemaId           String              @unique
  energiaGenerada     Decimal             @db.Decimal(12, 3)
  energiaConsumida    Decimal             @db.Decimal(12, 3)
  potenciaInstantanea Decimal             @db.Decimal(12, 3)
  balanceEnergetico   Decimal             @db.Decimal(12, 3)
  fechaLectura        DateTime
  sistema             SistemaFotovoltaico @relation(fields: [sistemaId], references: [id], onDelete: Cascade)

  @@index([fechaLectura])
  @@map("DatosTiempoReal")
}

/// @deprecated Modelo legacy del sistema anterior. No insertar datos nuevos.
/// Conservado por compatibilidad. Ver Dispositivo + HistorialDispositivo + LecturaUnificada.
model HistorialLectura {
  id                  BigInt              @id @default(autoincrement())
  sistemaId           String
  energiaGenerada     Decimal             @db.Decimal(12, 3)
  energiaConsumida    Decimal             @db.Decimal(12, 3)
  potenciaInstantanea Decimal             @db.Decimal(12, 3)
  balanceEnergetico   Decimal             @db.Decimal(12, 3)
  timestamp           DateTime            @db.Timestamp(3)
  sistema             SistemaFotovoltaico @relation(fields: [sistemaId], references: [id], onDelete: Cascade)

  @@index([sistemaId, timestamp])
  @@index([timestamp])
  @@map("HistorialLecturas")
}

/// @deprecated Modelo legacy del sistema anterior. No insertar datos nuevos.
/// Conservado por compatibilidad. Ver ResumenDispositivo.
model ResumenDiario {
  id                    BigInt              @id @default(autoincrement())
  sistemaId             String
  fecha                 DateTime            @db.Date
  energiaGeneradaTotal  Decimal             @db.Decimal(14, 3)
  energiaConsumidaTotal Decimal             @db.Decimal(14, 3)
  balanceTotal          Decimal             @db.Decimal(14, 3)
  sistema               SistemaFotovoltaico @relation(fields: [sistemaId], references: [id], onDelete: Cascade)

  @@unique([sistemaId, fecha])
  @@index([fecha])
  @@map("ResumenDiario")
}

/// @deprecated Modelo legacy del sistema anterior. No insertar datos nuevos.
/// Conservado por compatibilidad. Ver ResumenDispositivo.
model ResumenMensual {
  id                    BigInt              @id @default(autoincrement())
  sistemaId             String
  mes                   Int
  anio                  Int
  energiaGeneradaTotal  Decimal             @db.Decimal(14, 3)
  energiaConsumidaTotal Decimal             @db.Decimal(14, 3)
  balanceTotal          Decimal             @db.Decimal(14, 3)
  sistema               SistemaFotovoltaico @relation(fields: [sistemaId], references: [id], onDelete: Cascade)

  @@unique([sistemaId, mes, anio])
  @@index([anio, mes])
  @@map("ResumenMensual")
}

model Dispositivo {
  id                        String                       @id @default(cuid())
  usuarioId                 String
  nombre                    String
  tipo                      DeviceType
  modelo                    String
  fuenteDatos               DataSourceType
  estado                    DeviceStatus                 @default(OFFLINE)
  ultimoContacto            DateTime?
  intervaloMuestreoSegundos Int                          @default(5)
  claveIngestaHash          String
  metadata                  Json?
  activo                    Boolean                      @default(true)
  createdAt                 DateTime                     @default(now())
  updatedAt                 DateTime                     @updatedAt
  ultimaLecturas            UltimaLecturaDispositivo[]
  lecturas                  LecturaDispositivo[]
  lecturasUnificadas        LecturaUnificada[]
  historial                 HistorialDispositivo[]
  muestrasTemporales        MuestraTemporalDispositivo[]
  resumenes                 ResumenDispositivo[]
  usuario                   Usuario                      @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([usuarioId, activo, estado])
  @@index([usuarioId, activo, fuenteDatos])
  @@index([activo, estado])
  @@index([activo, fuenteDatos])
  @@index([tipo, activo])
  @@map("Dispositivos")
}

model LecturaDispositivo {
  id                 BigInt                @id @default(autoincrement())
  dispositivoId      String
  fuenteDatos        DataSourceType
  protocolo          IngestionProtocol     @default(HTTP_REST)
  voltaje            Decimal?              @db.Decimal(12, 3)
  corriente          Decimal?              @db.Decimal(12, 3)
  potencia           Decimal?              @db.Decimal(12, 3)
  energia            Decimal?              @db.Decimal(14, 3)
  promedioReferencia Decimal?              @db.Decimal(12, 3)
  payload            Json?
  timestamp          DateTime              @db.Timestamp(3)
  createdAt          DateTime              @default(now())
  dispositivo        Dispositivo           @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)
  historial          HistorialDispositivo?

  @@index([dispositivoId, timestamp(sort: Desc)])
  @@index([fuenteDatos, timestamp(sort: Desc)])
  @@map("LecturasDispositivos")
}

model LecturaUnificada {
  id                    BigInt            @id @default(autoincrement())
  dispositivoId         String
  protocolo             IngestionProtocol @default(HTTP_REST)
  voltaje               Decimal?          @db.Decimal(12, 3)
  corriente             Decimal?          @db.Decimal(12, 3)
  potenciaGeneracion    Decimal?          @db.Decimal(12, 3)
  potenciaConsumo       Decimal?          @db.Decimal(12, 3)
  energiaGeneracion     Decimal?          @db.Decimal(14, 3)
  energiaConsumo        Decimal?          @db.Decimal(14, 3)
  balanceEnergetico     Decimal?          @db.Decimal(12, 3)
  promedioRefGeneracion Decimal?          @db.Decimal(12, 3)
  promedioRefConsumo    Decimal?          @db.Decimal(12, 3)
  payload               Json?
  timestamp             DateTime          @db.Timestamp(3)
  createdAt             DateTime          @default(now())
  dispositivo           Dispositivo       @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)

  @@index([dispositivoId, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
  @@map("LecturasUnificadas")
}

model MuestraTemporalDispositivo {
  id            BigInt      @id @default(autoincrement())
  dispositivoId String
  potencia      Decimal     @db.Decimal(12, 3)
  timestamp     DateTime    @db.Timestamp(3)
  dispositivo   Dispositivo @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)

  @@index([dispositivoId, timestamp])
  @@map("MuestrasTemporalesDispositivos")
}

model UltimaLecturaDispositivo {
  id                 String         @id @default(cuid())
  dispositivoId      String
  fuenteDatos        DataSourceType
  voltaje            Decimal?       @db.Decimal(12, 3)
  corriente          Decimal?       @db.Decimal(12, 3)
  potencia           Decimal?       @db.Decimal(12, 3)
  energia            Decimal?       @db.Decimal(14, 3)
  promedioReferencia Decimal?       @db.Decimal(12, 3)
  fueraRango         Boolean        @default(false)
  payload            Json?
  fechaLectura       DateTime       @db.Timestamp(3)
  dispositivo        Dispositivo    @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)

  @@unique([dispositivoId, fuenteDatos])
  @@index([fuenteDatos, fechaLectura(sort: Desc)])
  @@index([fechaLectura(sort: Desc)])
  @@map("UltimasLecturasDispositivos")
}

model HistorialDispositivo {
  id                 BigInt              @id @default(autoincrement())
  dispositivoId      String
  lecturaId          BigInt?             @unique
  fuenteDatos        DataSourceType
  voltaje            Decimal?            @db.Decimal(12, 3)
  corriente          Decimal?            @db.Decimal(12, 3)
  potencia           Decimal?            @db.Decimal(12, 3)
  energia            Decimal?            @db.Decimal(14, 3)
  promedioReferencia Decimal?            @db.Decimal(12, 3)
  fueraRango         Boolean             @default(false)
  motivoGuardado     HistoryReason
  payload            Json?
  timestamp          DateTime            @db.Timestamp(3)
  dispositivo        Dispositivo         @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)
  lectura            LecturaDispositivo? @relation(fields: [lecturaId], references: [id], onDelete: SetNull)

  @@index([dispositivoId, timestamp(sort: Desc)])
  @@index([fuenteDatos, timestamp(sort: Desc)])
  @@index([timestamp(sort: Desc)])
  @@map("HistorialDispositivos")
}

model ConfiguracionMonitoreo {
  id                                String   @id @default(cuid())
  usuarioId                         String   @unique
  ventanaPromedioMinutos            Int      @default(15)
  desviacionSuperiorPuntos          Decimal  @default(4) @db.Decimal(12, 3)
  desviacionInferiorPuntos          Decimal  @default(4) @db.Decimal(12, 3)
  intervaloGuardadoNormalMinutos    Int      @default(15)
  intervaloGuardadoAnomaliaSegundos Int      @default(10)
  cambioSignificativoPuntos         Decimal  @default(0.25) @db.Decimal(12, 3)
  retencionLecturasDias             Int      @default(90)
  retencionHistorialDias            Int      @default(730)
  retencionResumenesMeses           Int      @default(60)
  createdAt                         DateTime @default(now())
  updatedAt                         DateTime @updatedAt
  usuario                           Usuario  @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@map("ConfiguracionMonitoreo")
}

model ResumenDispositivo {
  id               BigInt             @id @default(autoincrement())
  dispositivoId    String
  fuenteDatos      DataSourceType
  granularidad     SummaryGranularity
  periodoInicio    DateTime           @db.Timestamp(3)
  promedioPotencia Decimal            @db.Decimal(12, 3)
  minimoPotencia   Decimal            @db.Decimal(12, 3)
  maximoPotencia   Decimal            @db.Decimal(12, 3)
  muestras         Int                @default(0)
  fueraRango       Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  dispositivo      Dispositivo        @relation(fields: [dispositivoId], references: [id], onDelete: Cascade)

  @@unique([dispositivoId, fuenteDatos, granularidad, periodoInicio], map: "ResumenDispositivo_fuente_periodo_key")
  @@index([granularidad, periodoInicio(sort: Desc)])
  @@index([fuenteDatos, granularidad, periodoInicio(sort: Desc)])
  @@map("ResumenDispositivos")
}

model Auditoria {
  id         BigInt      @id @default(autoincrement())
  usuarioId  String?
  accion     AuditAction
  tabla      String
  registroId String?
  ip         String?
  detalle    Json?
  createdAt  DateTime    @default(now())
  usuario    Usuario?    @relation(fields: [usuarioId], references: [id], onDelete: SetNull)

  @@index([usuarioId, createdAt(sort: Desc)])
  @@index([tabla, registroId])
  @@index([accion, createdAt(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("Auditoria")
}
